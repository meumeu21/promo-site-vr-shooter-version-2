PORT=5001
BACKEND_HISTORY_INGEST_URL=http://backend:4000/api/history-ingest/matches
HISTORY_INGEST_TOKEN=replace_with_history_ingest_token
PUBLISH_INTERVAL_MS=15000
AUTO_START=false
# Keep empty for local-only control-plane access inside compose; set a value when host tools must call control endpoints.
CONTROL_TOKEN=
FIXTURE_SET=default
FIXTURE_COUNT=24
FIXTURE_SEED=default-seed
