PORT=4000
DATABASE_URL=postgres://shoter_user:shoter_password@db:5432/shoter_mvp
JWT_SECRET=replace_with_strong_random_jwt_secret
# Required admin credentials (set explicit non-default values)
ADMIN_VIEWER_LOGIN=replace_with_viewer_login
ADMIN_VIEWER_PASSWORD=replace_with_strong_viewer_password_required
ADMIN_OPERATOR_LOGIN=replace_with_operator_login
ADMIN_OPERATOR_PASSWORD=replace_with_strong_operator_password_required
API_VERSION=1.0.0
HISTORY_INGEST_TOKEN=replace_with_history_ingest_token
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_MAX=20
# Brute-force protection for POST /api/admin/login (per-IP, Redis-backed)
ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=60000
# Recommended safe default for MVP/dev: max 5 attempts per minute per IP
ADMIN_LOGIN_RATE_LIMIT_MAX=5
# Redis key prefix for admin login limiter
ADMIN_LOGIN_RATE_LIMIT_REDIS_PREFIX=rate-limit:admin-login
# Redis is required for admin login limiter (fail-closed to 503 when unavailable)
REDIS_URL=redis://redis:6379
REDIS_CONNECT_TIMEOUT_MS=2000
PUBLIC_RATE_LIMIT_REDIS_PREFIX=rate-limit:public
