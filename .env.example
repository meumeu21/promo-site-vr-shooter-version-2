POSTGRES_DB=shoter_mvp
POSTGRES_USER=shoter_user
POSTGRES_PASSWORD=shoter_password
POSTGRES_PORT=5432
HISTORY_INGEST_TOKEN=replace_with_history_ingest_token
# Optional shared local secret for guarded mock-server control-plane calls from host tools
MOCK_CONTROL_TOKEN=replace_with_local_control_token

# Compose host bindings for baseline host-visible entrypoints.
# These variables are used by docker compose when resolving published ports.
# They must live in root .env or be provided via shell environment; service env_file values are not used for ports interpolation.
# Security-first defaults bind only to localhost.
FRONTEND_HOST_IP=127.0.0.1
FRONTEND_HOST_PORT=3000
BACKEND_HOST_IP=127.0.0.1
BACKEND_HOST_PORT=4000

# Internal services stay hidden by default.
# BACKEND_HOST_* and the variables below are used only with [`docker-compose.host-access.yml`](docker-compose.host-access.yml).
DB_HOST_IP=127.0.0.1
DB_HOST_PORT=5432
REDIS_HOST_IP=127.0.0.1
REDIS_HOST_PORT=6379
MOCK_SERVER_HOST_IP=127.0.0.1
MOCK_SERVER_HOST_PORT=5001
